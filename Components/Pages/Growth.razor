@page "/growth"
@rendermode InteractiveServer

@using ToddlerActivityPlanner.Models
@inject ToddlerActivityPlanner.Services.GrowthService GrowthService
@inject ToddlerActivityPlanner.Services.ChildService ChildService
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="dashboard-card growth-form-card">
    <h3>📈 Add Growth Record</h3>
    <p>Track your child's height and weight over time.</p>
</div>

<h1>📈 Growth Tracker</h1>

@if (activeChild == null)
{
    <div class="alert alert-warning">
        Please select a child first.
    </div>
}
else
{
    <div class="active-child-banner">
        👶 Growth records for <strong>@activeChild.Name</strong>
    </div>

    <label>⚖️ Weight (kg)</label>
<input class="form-control"
       type="number"
       step="0.1"
       @bind="newRecord.WeightKg" />

<br />

<label>📏 Height (cm)</label>
<input class="form-control"
       type="number"
       step="0.1"
       @bind="newRecord.HeightCm" />


    <input class="form-control" type="date" @bind="newRecord.RecordDate" />
    <br />

    <button class="btn btn-primary growth-btn" @onclick="AddGrowth">
        Add Growth Record
    </button>

    <hr />
@if (growthRecords.Any())
{
    <div class="dashboard-card growth-chart-card">
        <h3>📈 Growth Trend</h3>

        <div class="growth-trend-list">
            @foreach (var record in ChartRecords)
            {
                <div class="growth-trend-item">
                    <strong>@record.RecordDate.ToString("dd MMM")</strong>
                    <span>⚖️ @record.WeightKg kg</span>
                    <span>📏 @record.HeightCm cm</span>
                </div>
            }
        </div>
    </div>
}
  @if (latestRecord != null)
{
    <div class="dashboard-card growth-summary-card">
        <h3>📈 Latest Growth</h3>
        <p><strong>⚖️ Weight:</strong> @latestRecord.WeightKg kg</p>
        <p><strong>📏 Height:</strong> @latestRecord.HeightCm cm</p>
        <p><strong>📅 Updated:</strong> @latestRecord.RecordDate.ToShortDateString()</p>
    </div>

    <br />
}
@if (growthRecords.Count >= 2)
{
    <div class="dashboard-card progress-card">
        <h3>📈 Growth Progress</h3>
        <p>⚖️ Weight Change: @weightChange kg</p>
        <p>📏 Height Change: @heightChange cm</p>
    </div>

    <br />
}
@foreach (var record in growthRecords)
{
    <div class="dashboard-card">
        <h3>📅 @record.RecordDate.ToShortDateString()</h3>
        <p>⚖️ Weight: @record.WeightKg kg</p>
        <p>📏 Height: @record.HeightCm cm</p>

        <button class="btn btn-danger btn-sm" @onclick="() => Delete(record.Id)">
            Delete
        </button>
    </div>
}
}

@code {
    private Child? activeChild;
    private List<GrowthRecord> growthRecords = new();
    private GrowthRecord newRecord = new();
    private GrowthRecord? latestRecord;
    
    private decimal weightChange;
    private decimal heightChange;
    protected override async Task OnInitializedAsync()
    {
       var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

if (string.IsNullOrWhiteSpace(userId))
{
    activeChild = null;
    return;
}

activeChild = (await ChildService.GetAllAsync(userId))
    .FirstOrDefault(c => c.IsActive);

        await LoadGrowthRecords();
    }

   private async Task LoadGrowthRecords()
{
    if (activeChild == null)
    {
        growthRecords = new();
        return;
    }

    growthRecords = await GrowthService.GetAllAsync(activeChild.Id);

    latestRecord = growthRecords.FirstOrDefault();

    if (growthRecords.Count >= 2)
    {
        var previous = growthRecords[1];

        weightChange = latestRecord!.WeightKg - previous.WeightKg;
        heightChange = latestRecord.HeightCm - previous.HeightCm;
    }
    else
    {
        weightChange = 0;
        heightChange = 0;
    }
}
    private async Task AddGrowth()
    {
        if (activeChild == null)
        {
            return;
        }

        newRecord.ChildId = activeChild.Id;

        await GrowthService.AddAsync(newRecord);

        newRecord = new GrowthRecord();
        await LoadGrowthRecords();
    }

    private List<GrowthRecord> ChartRecords =>
    growthRecords
        .OrderBy(x => x.RecordDate)
        .TakeLast(6)
        .ToList();

private decimal MaxWeight =>
    ChartRecords.Any() ? ChartRecords.Max(x => x.WeightKg) : 1;

private int GetWeightBarHeight(decimal weight)
{
    if (MaxWeight <= 0) return 10;

    var percent = (int)((weight / MaxWeight) * 100);
    return Math.Max(percent, 15);
}

    private async Task Delete(int id)
    {
        await GrowthService.DeleteAsync(id);
        await LoadGrowthRecords();
    }
}