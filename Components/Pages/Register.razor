@page "/register"
@rendermode InteractiveServer

@using ToddlerActivityPlanner.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<h1>📝 Register Parent</h1>

<input class="form-control"
       @bind="parentName"
       placeholder="Parent Name"
       autocomplete="name" />
<br />

<input class="form-control"
       @bind="phoneNumber"
       placeholder="Phone Number with country code, e.g. +971501234567"
       autocomplete="tel" />
<br />

<input class="form-control"
       @bind="email"
       placeholder="Email"
       autocomplete="off" />
<br />

<input class="form-control"
       type="password"
       @bind="password"
       placeholder="Password"
       autocomplete="new-password" />
<br />


<br />

<button class="btn btn-primary"
        @onclick="RegisterUser">
    Register
</button>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p class="text-danger">@message</p>
}

@code {
    private string parentName = "";
    private string phoneNumber = "";
    private string email = "";
    private string password = "";
    private string message = "";

    private async Task RegisterUser()
    {
        var user = new ApplicationUser
        {
            UserName = email,
            Email = email,
            ParentName = parentName,
            PhoneNumber = phoneNumber
        };

        if (string.IsNullOrWhiteSpace(parentName))
{
    message = "Please enter parent name.";
    return;
}

if (string.IsNullOrWhiteSpace(phoneNumber))
{
    message = "Please enter phone number with country code.";
    return;
}

if (!phoneNumber.StartsWith("+"))
{
    message = "Please include country code, example +971501234567.";
    return;
}

        var result = await UserManager.CreateAsync(user, password);

        if (result.Succeeded)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
        }
        else
        {
            message = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }
}