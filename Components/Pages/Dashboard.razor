@page "/dashboard"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using ToddlerActivityPlanner.Models

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject ToddlerActivityPlanner.Services.ChildService ChildService
@inject ToddlerActivityPlanner.Services.GrowthService GrowthService
@inject ToddlerActivityPlanner.Services.MilestoneService MilestoneService
@inject ToddlerActivityPlanner.Services.ActivityService ActivityService
@inject ToddlerActivityPlanner.Services.MealService MealService
@inject ToddlerActivityPlanner.Services.SleepService SleepService
@inject ToddlerActivityPlanner.Services.WaterService WaterService

<div class="v3-dashboard">

    <div class="v3-welcome">
        <div>
            <h1>👋 Good Evening, @displayName</h1>
            <p>Little Explorer is growing beautifully today.</p>
        </div>
    </div>

    @if (activeChild == null)
    {
        <div class="v3-card">
            <h2>👶 No active child selected</h2>
            <p>Please add or select a child profile to start tracking growth and milestones.</p>
            <a class="btn btn-primary" href="/children">Go to Child Profile</a>
        </div>
    }
    else
    {
        <div class="v3-hero-card">
            <div>
                <h2>👶 @activeChild.Name</h2>
                <p>@activeChild.Age years old</p>

                <h4>Development Score</h4>
                <div class="progress v3-progress">
                    <div class="progress-bar bg-success" style="width:@DevelopmentScore%">
                        @DevelopmentScore%
                    </div>
                </div>

                <a class="btn btn-light mt-3" href="/children">View Child Profile</a>
            </div>
<img src="@(string.IsNullOrWhiteSpace(activeChild?.PhotoPath)
        ? "/images/aarav.png"
        : activeChild.PhotoPath)"
     class="v3-avatar" />
        </div>

        <div class="v3-grid">
            <div class="v3-card growth-soft">
                <h3>📈 Growth</h3>

                @if (LatestGrowth != null)
                {
                    <h2>@LatestGrowth.WeightKg kg</h2>
                    <p>@LatestGrowth.HeightCm cm</p>
                    <small>Latest growth record</small>
                }
                else
                {
                    <h2>-</h2>
                    <p>No growth record yet</p>
                }
            </div>

            <div class="v3-card milestone-soft">
                <h3>🏆 Development</h3>
                <h2>@CompletedMilestones / @TotalMilestones</h2>
                <p>Milestones completed</p>

                <div class="progress">
                    <div class="progress-bar bg-success" style="width:@DevelopmentScore%">
                        @DevelopmentScore%
                    </div>
                </div>
            </div>

            <div class="v3-card ai-soft">
                <h3>🤖 AI Coach</h3>
                <p>@AiInsight</p>
                <a class="btn btn-outline-primary btn-sm" href="/ai-assistant">Ask AI Coach</a>
            </div>

            <div class="v3-card achievement-soft">

    <h3>🏆 Recent Achievements</h3>

    @if (RecentAchievements.Any())
    {
        @foreach (var item in RecentAchievements)
        {
            <div class="mb-3">

                <strong>✅ @item.Title</strong>

                <br />

                <small class="text-muted">
                    @item.DateCompleted?.ToString("dd MMM yyyy")
                </small>

            </div>
        }
    }
    else
    {
        <p>No milestones completed yet.</p>
    }

    <hr />

    <h5>🎯 Next Milestone</h5>

    @if (NextMilestone != null)
    {
        <strong>@NextMilestone.Title</strong>

        <br />

        <small>@NextMilestone.AgeRange</small>
    }
    else
    {
        <span class="text-success">
            🎉 All milestones completed!
        </span>
    }

</div>

            <div class="v3-card memory-soft">
                <h3>📸 Memories</h3>
                <p>Capture your child's special moments and milestones.</p>
                <a class="btn btn-outline-primary btn-sm" href="/memories">Open Memories</a>
            </div>
            <div class="v3-card mini-card">
    <h5>🍽 Meals</h5>
    <h2>@MealCount</h2>
    <small>Meals logged</small>
</div>

<div class="v3-card mini-card">
    <h5>💧 Water</h5>
    <h2>@WaterCups</h2>
    <small>Cups today</small>
</div>

<div class="v3-card mini-card">
    <h5>😴 Sleep</h5>
    <h2>@SleepCount</h2>
    <small>Sleep records</small>
</div>

<div class="v3-card mini-card">
    <h5>🎯 Activities</h5>
    <h2>@ActivityCount</h2>
    <small>Activities logged</small>
</div>
        </div>
    }
</div>

@code {
    private Child? activeChild;
    private string displayName = "Parent";
    private GrowthRecord? LatestGrowth;
    private int TotalMilestones;
    private int CompletedMilestones;

    private int ActivityCount;
    private int MealCount;
    private int SleepCount;
    private int WaterCups;  

    private List<Milestone> RecentAchievements = new();
    private Milestone? NextMilestone;
    private int DevelopmentScore =>
        TotalMilestones == 0 ? 0 : CompletedMilestones * 100 / TotalMilestones;

    private string AiInsight =>
        DevelopmentScore >= 80
            ? "Excellent progress! Keep encouraging learning through stories, play, and daily conversations."
            : DevelopmentScore >= 50
                ? "Good progress. Try focusing on a few pending milestones this week."
                : "Start with simple daily activities like reading, color games, and outdoor play.";

   protected override async Task OnParametersSetAsync()
{
    await LoadDashboard();
}

private async Task LoadDashboard()
{
    var authState =
        await AuthenticationStateProvider.GetAuthenticationStateAsync();

    var user = authState.User;

    if (user.Identity?.IsAuthenticated == true)
    {
        var appUser = await UserManager.GetUserAsync(user);

        if (appUser != null)
        {
            displayName = appUser.ParentName;
        }
    }

    var userId = user
        .FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)
        ?.Value;

    if (string.IsNullOrWhiteSpace(userId))
    {
        activeChild = null;
        return;
    }

    activeChild = (await ChildService.GetAllAsync(userId))
        .FirstOrDefault(c => c.IsActive);

    if (activeChild == null)
    {
        LatestGrowth = null;
        ActivityCount = 0;
        MealCount = 0;
        SleepCount = 0;
        WaterCups = 0;
        TotalMilestones = 0;
        CompletedMilestones = 0;
        RecentAchievements = new();
        NextMilestone = null;
        return;
    }

    LatestGrowth = (await GrowthService.GetAllAsync(activeChild.Id))
        .FirstOrDefault();

    ActivityCount =
        (await ActivityService.GetAllAsync(activeChild.Id)).Count;

    MealCount =
        (await MealService.GetAllAsync(activeChild.Id)).Count;

    SleepCount =
        (await SleepService.GetAllAsync(activeChild.Id)).Count;

    WaterCups =
        (await WaterService.GetAllAsync(activeChild.Id))
        .Sum(x => x.CupsDrank);

    var milestones =
        await MilestoneService.GetAllAsync(activeChild.Id);

    TotalMilestones = milestones.Count;

    CompletedMilestones =
        milestones.Count(x => x.IsCompleted);

    RecentAchievements = milestones
        .Where(x => x.IsCompleted)
        .OrderByDescending(x => x.DateCompleted)
        .Take(3)
        .ToList();

    NextMilestone =
        milestones.FirstOrDefault(x => !x.IsCompleted);
}
}