@page "/children"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ToddlerActivityPlanner.Models

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ToddlerActivityPlanner.Services.ChildService ChildService
@inject ToddlerActivityPlanner.Services.MilestoneService MilestoneService


<h1>👶 My Child</h1>
<p class="page-subtitle">Manage your child profile and active child.</p>

<div class="child-form-card">
<label>Child Name</label>
<input class="form-control" @bind="newChild.Name" placeholder="Enter child name" />

<br />

<label>Age</label>
<input class="form-control" type="number" @bind="newChild.Age" placeholder="Enter age" />

<br />

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<button class="btn btn-primary" @onclick="AddChild">
    Add Child
</button>
</div>
<hr />

@foreach (var child in children)
{
    <div class="child-profile-card">
        <h3>👶 @child.Name</h3>
        <span class="child-age-badge">Age: @child.Age years</span>

        @if (child.IsActive)
        {
            <span class="badge bg-success">⭐ Active Child</span>
            <div class="mt-3">
    <strong>🏆 Development Score</strong>
    <div class="progress mt-2">
        <div class="progress-bar bg-success"
             style="width:@childScores.GetValueOrDefault(child.Id, 0)%">
            @childScores.GetValueOrDefault(child.Id, 0)%
        </div>
    </div>
</div>
        }
        else
        {
            <button class="btn btn-outline-primary btn-sm"
                @onclick="() => SetActive(child.Id)">
            Select
        </button>
        }

    <a class="btn btn-primary btn-sm"
   href="/child-profile/@child.Id">
    👶 View Profile
</a>

        <button class="btn btn-danger btn-sm"
                @onclick="() => DeleteChild(child.Id)">
            Delete
        </button>
    </div>
}
@code {
    private List<Child> children = new();
    private Child newChild = new();
    private string errorMessage = "";
    private Dictionary<int, int> childScores = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadChildren();
    }

    private async Task AddChild()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(newChild.Name))
        {
            errorMessage = "Please enter child name.";
            return;
        }

        if (!newChild.Age.HasValue || newChild.Age <= 0)
        {
            errorMessage = "Please enter valid age.";
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            errorMessage = "Please login before adding a child.";
            return;
        }

        newChild.UserId = userId;

        await ChildService.AddAsync(newChild);
        await MilestoneService.SeedDefaultMilestonesAsync(newChild.Id, newChild.Age ?? 0);
        newChild = new Child();
        await LoadChildren();
    }
    private async Task LoadChildren()
    {
    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    if (string.IsNullOrWhiteSpace(userId))
    {
        children = new();
        return;
    }

    children = await ChildService.GetAllAsync(userId);
    childScores.Clear();

foreach (var child in children)
{
    var milestones = await MilestoneService.GetAllAsync(child.Id);
    var total = milestones.Count;
    var completed = milestones.Count(x => x.IsCompleted);

    childScores[child.Id] = total == 0 ? 0 : completed * 100 / total;
}
    }

    private async Task DeleteChild(int id)
    {
        await ChildService.DeleteAsync(id);
        await LoadChildren();
    }

   private async Task SetActive(int id)
{
    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    if (string.IsNullOrWhiteSpace(userId))
    {
        errorMessage = "Please login first.";
        return;
    }

    await ChildService.SetActiveAsync(id, userId);
    await LoadChildren();
}
}